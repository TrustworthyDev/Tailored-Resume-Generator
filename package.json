{
  "name": "careerva",
  "version": "1.0.0",
  "description": "Careerva - generate tailored resumes and track job applications",
  "private": true,
  "main": "electron/main.js",
  "author": "Hayashi Benjiro",
  "scripts": {
    "dev:next": "next dev renderer -p 3000",
    "dev:electron": "wait-on tcp:127.0.0.1:3000 && cross-env ELECTRON_DEV=1 electron .",
    "dev": "concurrently -k -n NEXT,ELECTRON -c blue,green \"npm:dev:next\" \"npm:dev:electron\"",
    "build:next": "next build renderer",
    "start": "npm run build:next && electron .",
    "dist": "npm run build:next && electron-builder",
    "dist:dir": "npm run build:next && electron-builder --dir"
  },
  "dependencies": {
    "flag-icons": "^7.5.0",
    "marked": "^18.0.4",
    "sql.js": "^1.10.3",
    "undici": "6.19.8"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.careerva.app",
    "productName": "Careerva",
    "files": [
      "electron/**/*",
      "renderer/out/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/undici/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "afterPack": "build/afterPack.js",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
