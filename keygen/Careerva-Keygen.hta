<!doctype html>
<html>
<head>
<meta http-equiv="x-ua-compatible" content="ie=edge" />
<title>Careerva Keygen</title>
<hta:application
  id="kg"
  applicationname="Careerva Keygen"
  border="thin"
  borderstyle="normal"
  caption="yes"
  maximizebutton="no"
  minimizebutton="yes"
  scroll="no"
  singleinstance="yes"
  innerborder="no" />
<style>
  body {
    margin: 0; font-family: "Segoe UI", Arial, sans-serif;
    background: #0f1115; color: #e6e8ec; overflow: hidden;
  }
  .wrap { padding: 24px 26px; }
  h1 { margin: 0 0 4px; font-size: 18px; }
  p { color: #8b93a1; font-size: 12px; margin: 6px 0 0; }
  label { display: block; margin: 16px 0 6px; color: #8b93a1; font-size: 12px; }
  input {
    width: 100%; background: #1f232c; border: 1px solid #2a2f3a; color: #e6e8ec;
    border-radius: 8px; padding: 10px 12px; font-size: 14px;
  }
  button {
    margin-top: 14px; background: #4f8cff; border: 0; color: #fff;
    padding: 10px 18px; border-radius: 8px; font-size: 14px; cursor: pointer;
  }
  .key {
    margin-top: 16px; background: #11151c; border: 1px solid #2a2f3a; border-radius: 9px;
    padding: 16px; font-family: Consolas, monospace; font-size: 20px; letter-spacing: 1px;
    text-align: center; color: #4ccb8b;
  }
  .muted { color: #8b93a1; font-size: 11px; margin-top: 14px; }
</style>
</head>
<body>
<div class="wrap">
  <h1>Careerva &mdash; Key Generator</h1>
  <p>Paste the Machine ID from the app (Settings &rsaquo; Security) and click Generate.</p>

  <label>Machine ID</label>
  <input type="text" id="mid" placeholder="XXXX-XXXX-XXXX-XXXX" />

  <button onclick="makeKey()">Generate Key</button>

  <label>License Key</label>
  <div class="key" id="out">&mdash;</div>

  <button onclick="copyKey()">Copy Key</button>

  <div class="muted">Keep this tool private &mdash; it can generate keys for any machine.</div>
</div>

<script type="text/javascript">
// MUST match electron/license.js
var SECRET = "Careerva-9f4Qe2$Kx7!pZr3@Lm8#Vn1&Hb6^Wd0-v1";

window.onload = function () { try { window.resizeTo(560, 530); } catch (e) {} };

function copyKey() {
  var k = document.getElementById("out").innerText;
  if (!k || k.length < 10) return; // nothing generated yet
  try { window.clipboardData.setData("Text", k); alert("Copied: " + k); }
  catch (e) { alert("Could not copy. Select the key and press Ctrl+C."); }
}

function utf8(s) {
  var o = [], i, c;
  for (i = 0; i < s.length; i++) {
    c = s.charCodeAt(i);
    if (c < 128) o.push(c);
    else if (c < 2048) { o.push(192 | (c >> 6)); o.push(128 | (c & 63)); }
    else { o.push(224 | (c >> 12)); o.push(128 | ((c >> 6) & 63)); o.push(128 | (c & 63)); }
  }
  return o;
}
var K = [
  0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,
  0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,
  0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,
  0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,
  0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,
  0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,
  0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,
  0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2
];
function rotr(n, x) { return (x >>> n) | (x << (32 - n)); }
function sha256H(bytes) {
  var H = [0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19];
  var m = bytes.slice(0), bitLen = m.length * 8, i, t;
  m.push(0x80);
  while (m.length % 64 !== 56) m.push(0);
  for (i = 7; i >= 0; i--) m.push((Math.floor(bitLen / Math.pow(2, 8 * i))) & 0xff);
  var w = new Array(64);
  for (var blk = 0; blk < m.length; blk += 64) {
    for (t = 0; t < 16; t++)
      w[t] = ((m[blk + 4 * t] << 24) | (m[blk + 4 * t + 1] << 16) | (m[blk + 4 * t + 2] << 8) | m[blk + 4 * t + 3]) >>> 0;
    for (t = 16; t < 64; t++) {
      var s0 = rotr(7, w[t - 15]) ^ rotr(18, w[t - 15]) ^ (w[t - 15] >>> 3);
      var s1 = rotr(17, w[t - 2]) ^ rotr(19, w[t - 2]) ^ (w[t - 2] >>> 10);
      w[t] = (w[t - 16] + s0 + w[t - 7] + s1) >>> 0;
    }
    var a = H[0], b = H[1], c = H[2], d = H[3], e = H[4], f = H[5], g = H[6], h = H[7];
    for (t = 0; t < 64; t++) {
      var S1 = rotr(6, e) ^ rotr(11, e) ^ rotr(25, e);
      var ch = (e & f) ^ ((~e) & g);
      var t1 = (h + S1 + ch + K[t] + w[t]) >>> 0;
      var S0 = rotr(2, a) ^ rotr(13, a) ^ rotr(22, a);
      var maj = (a & b) ^ (a & c) ^ (b & c);
      var t2 = (S0 + maj) >>> 0;
      h = g; g = f; f = e; e = (d + t1) >>> 0; d = c; c = b; b = a; a = (t1 + t2) >>> 0;
    }
    H[0] = (H[0] + a) >>> 0; H[1] = (H[1] + b) >>> 0; H[2] = (H[2] + c) >>> 0; H[3] = (H[3] + d) >>> 0;
    H[4] = (H[4] + e) >>> 0; H[5] = (H[5] + f) >>> 0; H[6] = (H[6] + g) >>> 0; H[7] = (H[7] + h) >>> 0;
  }
  return H;
}
function hToBytes(H) {
  var o = [], i, h;
  for (i = 0; i < H.length; i++) { h = H[i]; o.push((h >>> 24) & 255); o.push((h >>> 16) & 255); o.push((h >>> 8) & 255); o.push(h & 255); }
  return o;
}
function hToHex(H) {
  var s = "", i;
  for (i = 0; i < H.length; i++) s += ("00000000" + ((H[i] >>> 0).toString(16))).slice(-8);
  return s;
}
function hmacHex(keyStr, msgStr) {
  var key = utf8(keyStr), i;
  if (key.length > 64) key = hToBytes(sha256H(key));
  while (key.length < 64) key.push(0);
  var ipad = [], opad = [];
  for (i = 0; i < 64; i++) { ipad.push(key[i] ^ 0x36); opad.push(key[i] ^ 0x5c); }
  var inner = hToBytes(sha256H(ipad.concat(utf8(msgStr))));
  return hToHex(sha256H(opad.concat(inner))).toUpperCase();
}
function normalize(s) { return (s || "").replace(/[^a-z0-9]/gi, "").toUpperCase(); }
function makeKey() {
  var mid = normalize(document.getElementById("mid").value);
  var out = document.getElementById("out");
  if (!mid) { out.innerHTML = "&mdash;"; return; }
  var sig = hmacHex(SECRET, mid).substr(0, 20);
  out.innerText = sig.substr(0, 4) + "-" + sig.substr(4, 4) + "-" + sig.substr(8, 4) + "-" + sig.substr(12, 4) + "-" + sig.substr(16, 4);
}
</script>
</body>
</html>
